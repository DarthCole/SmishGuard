<?xml version="1.0" encoding="utf-8"?>
<!--
  ic_warning_dot.xml — Red Warning Dot Drawable
  ================================================
  This is a VECTOR DRAWABLE — an SVG-like image defined in XML.
  Unlike bitmap images (PNG/JPG), vectors scale to ANY size without
  becoming blurry. This red circle is the fraud indicator dot.
  
  "android:fillColor" sets the shape's fill color.
  The circle is drawn using an arc path in SVG path syntax.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Outer red circle -->
    <path
        android:fillColor="#D32F2F"
        android:pathData="M12,2C6.48,2 2,6.48 2,12s4.48,10 10,10 10,-4.48 10,-10S17.52,2 12,2z" />
    <!-- Inner white exclamation mark -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M13,17h-2v-2h2v2zM13,13h-2V7h2v6z" />
</vector>
