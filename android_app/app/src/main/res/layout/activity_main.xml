<!--
  activity_main.xml — Main Activity Layout
  ==========================================
  This is the ROOT LAYOUT for the main screen.
  
  XML LAYOUT BASICS:
    - Each XML tag represents a UI element (View)
    - "android:id" gives the View a unique name for code access
    - "android:layout_width/height" controls size:
        "match_parent" = fill the parent container
        "wrap_content" = shrink to fit the content
        "0dp" (in ConstraintLayout) = calculated from constraints
    - "dp" = density-independent pixels (scales with screen density)
    - "sp" = scale-independent pixels (scales with font size setting)
    
  CONSTRAINTLAYOUT:
    The most flexible Android layout. Each View's position is defined
    by CONSTRAINTS (connections) to other Views or the parent edges.
    Think of it like connecting rubber bands between UI elements.
    
    "app:layout_constraintTop_toTopOf="parent"" means:
    "Connect my TOP edge to the TOP of the parent container"
-->
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.main.MainActivity">

    <!-- ── Toolbar (Top App Bar) ── -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        android:elevation="4dp"
        app:titleTextColor="@color/white"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ══════════════════════════════════════════════════ -->
    <!-- Protection Toggle Card                            -->
    <!-- ══════════════════════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_protection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Shield icon placeholder -->
            <ImageView
                android:id="@+id/icon_shield"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_shield"
                android:contentDescription="Shield icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Protection status text -->
            <TextView
                android:id="@+id/text_protection_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Protection is OFF"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/icon_shield"
                app:layout_constraintEnd_toStartOf="@id/switch_protection"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- ON/OFF Toggle Switch -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_protection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ══════════════════════════════════════════════════ -->
    <!-- Fragment Container (holds Conversations/Settings) -->
    <!-- ══════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/card_protection"
        app:layout_constraintBottom_toBottomOf="parent" />
    <!--
      "0dp" height + top/bottom constraints = "fill remaining space"
      This is ConstraintLayout's way of making an element expand to
      fill the space between two other elements.
    -->

</androidx.constraintlayout.widget.ConstraintLayout>
