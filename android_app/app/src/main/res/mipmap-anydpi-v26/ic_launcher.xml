<!--
  ic_launcher.xml — Adaptive Icon (Foreground Layer)
  =====================================================
  Android 8.0+ uses "adaptive icons" with separate foreground and
  background layers. This allows the system to apply different shapes
  (circle, squircle, etc.) based on the device manufacturer.
  
  For now, this uses the shield drawable as the foreground.
  In production, you'd create proper launcher icon assets.
-->
<?xml version="1.0" encoding="utf-8"?>
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/primary" />
    <foreground android:drawable="@drawable/ic_shield" />
</adaptive-icon>
